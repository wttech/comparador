<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Acme{% endblock %} - {{ env.name }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        :root {
            --bs-primary: #c41e3a;
            --bs-primary-rgb: 196, 30, 58;
            --bs-warning: #f4c430;
            --bs-warning-rgb: 244, 196, 48;
            --bs-dark: #1a1a2e;
            --bs-dark-rgb: 26, 26, 46;
            --accent-gradient: linear-gradient(135deg, #c41e3a 0%, #8b0000 100%);
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        .navbar {
            background: var(--accent-gradient) !important;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .navbar-brand img {
            border-radius: 4px;
            margin-right: 0.5rem;
        }

        .hero-section {
            background: linear-gradient(135deg, {{ env.color }}22 0%, {{ env.color }}44 100%);
            padding: 80px 0;
            margin-bottom: 40px;
            border-bottom: 4px solid var(--bs-primary);
        }

        .btn-primary {
            background: var(--accent-gradient);
            border: none;
            font-weight: 500;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #a01830 0%, #6b0000 100%);
        }

        .card {
            border: none;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        }

        footer {
            background: var(--bs-dark) !important;
        }

        .stats-card {
            border-left: 4px solid var(--bs-primary);
        }

        {% block extra_styles %}{% endblock %}
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="https://picsum.photos/seed/{{ env.id }}-logo/40/40" alt="Logo">
                Acme
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link {% if page == 'home' %}active{% endif %}" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if page == 'products' %}active{% endif %}" href="/products">Products</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if page == 'about' %}active{% endif %}" href="/about">About</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    {% block content %}{% endblock %}

    {% if variant and variant.announcement and page == 'home' %}
    <div class="bg-warning text-dark text-center py-2 fw-bold">
        {{ variant.announcement }}
    </div>
    {% endif %}

    <footer class="text-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">© 2026 Acme Corp. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
</body>

</html>